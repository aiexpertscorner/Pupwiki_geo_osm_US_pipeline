from __future__ import annotations

import json
import sys
import time
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Iterable

from .categories import load_category_config, match_category
from .jsonx import dumps

DEFAULT_PROGRESS_EVERY = 500_000
DEFAULT_PROGRESS_SECONDS = 20.0
DEFAULT_BATCH_SIZE = 50_000


class _StopExtraction(Exception):
    pass


def _as_set(value: Iterable[str] | str | None) -> set[str] | None:
    if value is None:
        return None
    if isinstance(value, str):
        parts = value.replace(";", ",").split(",")
    else:
        parts = []
        for v in value:
            parts.extend(str(v).replace(";", ",").split(","))
    result = {p.strip() for p in parts if p and p.strip()}
    return result or None


def _cats(config: dict[str, Any]) -> list[dict[str, Any]]:
    return list(config.get("categories", []))


def _cat_ids(config: dict[str, Any]) -> set[str]:
    ids = set()
    for c in _cats(config):
        if c.get("id"):
            ids.add(c["id"])
        ids.update(c.get("legacyIds", []))
    return {str(x) for x in ids}


def _preset(config: dict[str, Any], value: str) -> set[str]:
    v = value.strip().lower()
    cats = _cats(config)
    if v in {"all", "*"}:
        return {c["id"] for c in cats if c.get("id")}
    if v in {"core", "tier-a", "a", "mvp", "indexable"}:
        return {
            c["id"]
            for c in cats
            if c.get("id") and (c.get("tier") == "A" or c.get("indexable") is True)
        }
    if v in {"tier-b", "b"}:
        return {c["id"] for c in cats if c.get("id") and c.get("tier") == "B"}
    if v in {"tier-c", "c"}:
        return {c["id"] for c in cats if c.get("id") and c.get("tier") == "C"}
    return set()


def _parse_selection(raw: str, config: dict[str, Any]) -> set[str]:
    raw = (raw or "").strip()
    if not raw:
        return _preset(config, "core")
    if preset := _preset(config, raw):
        return preset

    cats = _cats(config)
    by_num = {str(i): c["id"] for i, c in enumerate(cats, 1) if c.get("id")}
    by_id = {str(c["id"]): c for c in cats if c.get("id")}
    legacy = {
        str(x): c["id"]
        for c in cats
        for x in c.get("legacyIds", [])
        if c.get("id")
    }

    if raw.startswith("?") or raw.lower().startswith("q:"):
        q = raw[1:] if raw.startswith("?") else raw.split(":", 1)[1]
        q = q.strip().lower()
        return {
            c["id"]
            for c in cats
            if c.get("id")
            and q
            and q
            in " ".join(
                str(c.get(k, "")) for k in ("id", "label", "description", "tier")
            ).lower()
        }

    selected: set[str] = set()
    for token in raw.replace(";", ",").split(","):
        t = token.strip()
        if not t:
            continue
        tl = t.lower()
        if t in by_num:
            selected.add(by_num[t])
        elif t in by_id:
            selected.add(t)
        elif tl in by_id:
            selected.add(tl)
        elif t in legacy:
            selected.add(legacy[t])
        elif tl in legacy:
            selected.add(legacy[tl])
        else:
            selected.update(cid for cid in by_id if tl in cid.lower())
    return selected


def _resolve_category_arg(
    value: Iterable[str] | str | None,
    config: dict[str, Any],
) -> set[str] | None:
    """Resolve category CLI input.

    Supports presets such as core/all/tier-b, comma-separated category IDs,
    legacy IDs, numeric menu selections, and ?query searches.
    """
    if value is None:
        return None
    if isinstance(value, str):
        parsed = _parse_selection(value, config)
        return parsed or None

    selected: set[str] = set()
    for part in value:
        selected.update(_parse_selection(str(part), config))
    return selected or None


def _print_menu(config: dict[str, Any]) -> None:
    print("\nPupWiki OSM dog POI category selection")
    print("Presets: core / tier-a / tier-b / tier-c / all")
    print("Search: ?vet, ?park, ?groom, ?walk")
    print("Select: 1,3,dog-parks or veterinary-clinics,dog-grooming")
    print("-" * 100)
    for i, c in enumerate(_cats(config), 1):
        print(
            f"{i:>2}. {c.get('id', ''):<30} "
            f"tier={c.get('tier', '?')} "
            f"{'index' if c.get('indexable') else 'support':<7} "
            f"{c.get('label', '')}"
        )
    print("-" * 100)


def _should_prompt(interactive: bool | None) -> bool:
    if interactive is True:
        return True
    if interactive is False:
        return False
    return bool(sys.stdin and sys.stdin.isatty() and sys.stdout and sys.stdout.isatty())


def _object_types(value: Iterable[str] | str | None) -> set[str] | None:
    raw = _as_set(value)
    if raw is None:
        return None
    aliases = {
        "node": "node",
        "nodes": "node",
        "n": "node",
        "way": "way",
        "ways": "way",
        "w": "way",
        "relation": "relation",
        "relations": "relation",
        "r": "relation",
    }
    return {aliases[x.lower()] for x in raw if x.lower() in aliases} or None


def _human(n: int) -> str:
    x = float(n)
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if x < 1024 or unit == "TB":
            return f"{x:.1f}{unit}"
        x /= 1024
    return str(n)


def _elapsed(start: float) -> str:
    s = int(time.time() - start)
    h, rem = divmod(s, 3600)
    m, sec = divmod(rem, 60)
    return f"{h:02d}:{m:02d}:{sec:02d}"


class _Writer:
    def __init__(self, out: Path, batch_size: int | None, overwrite: bool) -> None:
        self.out = out
        self.batch_size = batch_size if batch_size and batch_size > 0 else None
        self.files: list[str] = []
        self.part = 0
        self.rows_in_part = 0
        self.total = 0
        self.f = None

        out.parent.mkdir(parents=True, exist_ok=True)

        if self.batch_size and overwrite:
            for old in out.parent.glob(f"{out.stem}.part-*{out.suffix or '.ndjson'}"):
                old.unlink(missing_ok=True)

        if not self.batch_size:
            if out.exists() and not overwrite:
                raise FileExistsError(out)
            self.f = out.open("wb")
            self.files.append(str(out))

    def _next(self) -> None:
        if self.f:
            self.f.flush()
            self.f.close()
        self.part += 1
        suffix = self.out.suffix or ".ndjson"
        path = self.out.parent / f"{self.out.stem}.part-{self.part:05d}{suffix}"
        self.f = path.open("wb")
        self.files.append(str(path))
        self.rows_in_part = 0

    def write(self, row: dict[str, Any]) -> None:
        if self.batch_size and (self.f is None or self.rows_in_part >= self.batch_size):
            self._next()
        if self.f is None:
            raise RuntimeError("writer not open")
        self.f.write(dumps(row))
        self.f.write(b"\n")
        self.total += 1
        self.rows_in_part += 1
        if self.total % 1000 == 0:
            self.f.flush()

    def bytes(self) -> int:
        return sum(Path(x).stat().st_size for x in self.files if Path(x).exists())

    def close(self) -> None:
        if self.f:
            self.f.flush()
            self.f.close()
            self.f = None

    def manifest(self, stats: dict[str, Any]) -> None:
        if self.batch_size:
            (self.out.parent / f"{self.out.stem}.manifest.json").write_text(
                json.dumps(
                    {"baseOutput": str(self.out), "parts": self.files, "stats": stats},
                    indent=2,
                ),
                encoding="utf-8",
            )


def _write_stats(path: Path, stats: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(stats, indent=2), encoding="utf-8")
    tmp.replace(path)


def extract_osm_pbf(
    pbf: str | Path,
    out: str | Path,
    *,
    category_config: str | None = None,
    keep_other: bool = False,
    include_categories: Iterable[str] | str | None = None,
    exclude_categories: Iterable[str] | str | None = None,
    object_types: Iterable[str] | str | None = None,
    interactive: bool | None = None,
    batch_size: int | None = None,
    progress_every: int = DEFAULT_PROGRESS_EVERY,
    progress_seconds: float = DEFAULT_PROGRESS_SECONDS,
    max_objects: int | None = None,
    max_written: int | None = None,
    stats_path: str | Path | None = None,
    overwrite: bool = True,
    location_index: str = "sparse_mem_array",
) -> dict[str, Any]:
    try:
        import osmium
    except Exception as exc:
        raise RuntimeError("Install pyosmium/osmium first: pip install osmium") from exc

    pbf = Path(pbf)
    out = Path(out)

    if not pbf.exists():
        raise FileNotFoundError(pbf)
    if pbf.stat().st_size < 1_000_000:
        raise ValueError(f"PBF is suspiciously small ({pbf.stat().st_size} bytes): {pbf}")

    config = load_category_config(category_config)
    include_set = _resolve_category_arg(include_categories, config)
    exclude_set = _resolve_category_arg(exclude_categories, config)
    obj_types = _object_types(object_types)

    if _should_prompt(interactive):
        if include_set is None:
            _print_menu(config)
            include_set = _parse_selection(
                input("Welke categories extracten? [core] > ").strip(),
                config,
            )
        if obj_types is None:
            print("\nObject types:\n1. nodes only  = snelste smoke test\n2. nodes+ways  = beste output\n3. ways only")
            raw = input("Welke object types? [1 voor snelle test] > ").strip().lower()
            obj_types = (
                {"node", "way"}
                if raw in {"2", "both", "all"}
                else ({"way"} if raw in {"3", "way", "ways"} else {"node"})
            )
        if batch_size is None:
            raw = input(f"Batch output? regels per part, 0=single file [{DEFAULT_BATCH_SIZE}] > ").strip()
            batch_size = DEFAULT_BATCH_SIZE if raw == "" else max(0, int(raw))
        if max_written is None:
            raw = input("Max geschreven POIs voor test? Enter=geen limiet, bijv. 1000 > ").strip()
            max_written = int(raw) if raw else None
        if max_objects is None:
            raw = input("Max OSM objecten scannen voor smoke test? Enter=geen limiet > ").strip()
            max_objects = int(raw) if raw else None
    else:
        obj_types = obj_types or {"node", "way"}

    valid = _cat_ids(config)
    if include_set:
        bad = include_set - valid
        if bad:
            raise ValueError(f"Unknown include categories: {sorted(bad)}")
    if exclude_set:
        bad = exclude_set - valid
        if bad:
            raise ValueError(f"Unknown exclude categories: {sorted(bad)}")

    writer = _Writer(out, batch_size, overwrite)
    stats_file = Path(stats_path) if stats_path else out.parent / f"{out.stem}.stats.json"
    start = time.time()
    next_progress = max(1, progress_every)
    last_progress = time.time()

    stats: dict[str, Any] = {
        "startedAt": datetime.now(timezone.utc).isoformat(),
        "finishedAt": None,
        "pbf": str(pbf),
        "pbfBytes": pbf.stat().st_size,
        "output": str(out),
        "outputMode": "batched" if batch_size and batch_size > 0 else "single",
        "batchSize": batch_size if batch_size and batch_size > 0 else None,
        "objectTypes": sorted(obj_types),
        "includeCategories": sorted(include_set) if include_set else None,
        "excludeCategories": sorted(exclude_set) if exclude_set else None,
        "keepOther": keep_other,
        "nodes": 0,
        "ways": 0,
        "relations": 0,
        "objectsScanned": 0,
        "written": 0,
        "byCategory": {},
        "skippedNoCategory": 0,
        "skippedExcludedCategory": 0,
        "skippedNoLocation": 0,
        "skippedObjectType": 0,
        "limitReached": None,
        "outputBytes": 0,
        "outputFiles": [],
    }

    def progress(force: bool = False) -> None:
        nonlocal next_progress, last_progress
        now = time.time()
        scanned = int(stats["objectsScanned"])
        if not force and scanned < next_progress and now - last_progress < progress_seconds:
            return
        stats["outputBytes"] = writer.bytes()
        stats["outputFiles"] = writer.files
        cats = ", ".join(f"{k}:{v}" for k, v in sorted(stats["byCategory"].items())) or "none yet"
        print(
            f"[extract-osm] elapsed={_elapsed(start)} "
            f"scanned={scanned:,} nodes={stats['nodes']:,} ways={stats['ways']:,} "
            f"relations={stats['relations']:,} written={stats['written']:,} "
            f"out={_human(stats['outputBytes'])} categories={cats}",
            flush=True,
        )
        _write_stats(stats_file, stats)
        last_progress = now
        while next_progress <= scanned:
            next_progress += max(1, progress_every)

    def check_limits() -> None:
        if max_objects and stats["objectsScanned"] >= max_objects:
            stats["limitReached"] = f"max_objects={max_objects}"
            raise _StopExtraction()
        if max_written and stats["written"] >= max_written:
            stats["limitReached"] = f"max_written={max_written}"
            raise _StopExtraction()

    def write_obj(obj, osm_type: str, lat: float | None, lon: float | None) -> None:
        if lat is None or lon is None:
            stats["skippedNoLocation"] += 1
            return

        tags = {str(k): str(v) for k, v in obj.tags}
        cat, conf, meta = match_category(tags, config)
        if not cat:
            stats["skippedNoCategory"] += 1
            if not keep_other:
                return
            cat = "other"

        if include_set and cat not in include_set:
            stats["skippedExcludedCategory"] += 1
            return
        if exclude_set and cat in exclude_set:
            stats["skippedExcludedCategory"] += 1
            return

        row = {
            "osmType": osm_type,
            "osmId": int(obj.id),
            "id": f"{osm_type}_{int(obj.id)}",
            "lat": float(lat),
            "lon": float(lon),
            "categoryHint": cat,
            "confidenceHint": conf,
            "matchMeta": meta,
            "tags": tags,
            "source": {
                "provider": "openstreetmap",
                "license": "ODbL",
                "extractedAt": datetime.now(timezone.utc).isoformat(),
            },
        }
        writer.write(row)
        stats["written"] += 1
        stats["byCategory"][cat] = stats["byCategory"].get(cat, 0) + 1
        check_limits()

    class Handler(osmium.SimpleHandler):
        def node(self, n):
            stats["nodes"] += 1
            stats["objectsScanned"] += 1
            if "node" not in obj_types:
                stats["skippedObjectType"] += 1
                progress()
                check_limits()
                return
            if n.tags:
                try:
                    loc_ok = n.location and n.location.valid()
                    write_obj(
                        n,
                        "node",
                        n.location.lat if loc_ok else None,
                        n.location.lon if loc_ok else None,
                    )
                except Exception:
                    stats["skippedNoLocation"] += 1
            progress()
            check_limits()

        def way(self, w):
            stats["ways"] += 1
            stats["objectsScanned"] += 1
            if "way" not in obj_types:
                stats["skippedObjectType"] += 1
                progress()
                check_limits()
                return
            if w.tags:
                coords = []
                for node in w.nodes:
                    try:
                        if node.location and node.location.valid():
                            coords.append((node.location.lat, node.location.lon))
                    except Exception:
                        pass
                if coords:
                    write_obj(
                        w,
                        "way",
                        sum(x for x, _ in coords) / len(coords),
                        sum(y for _, y in coords) / len(coords),
                    )
                else:
                    stats["skippedNoLocation"] += 1
            progress()
            check_limits()

        def relation(self, r):
            stats["relations"] += 1
            stats["objectsScanned"] += 1
            stats["skippedObjectType"] += 1
            progress()
            check_limits()

    print(
        f"[extract-osm] starting pbf={pbf} size={_human(pbf.stat().st_size)} "
        f"out={out} mode={stats['outputMode']} "
        f"objectTypes={','.join(sorted(obj_types))} "
        f"include={stats['includeCategories'] or 'all'}",
        flush=True,
    )

    handler = Handler()
    try:
        if "way" in obj_types:
            handler.apply_file(str(pbf), locations=True, idx=location_index)
        else:
            handler.apply_file(str(pbf), locations=False)
    except _StopExtraction:
        print(f"[extract-osm] stopped by limit: {stats['limitReached']}", flush=True)
    finally:
        writer.close()
        stats["outputBytes"] = writer.bytes()
        stats["outputFiles"] = writer.files
        stats["finishedAt"] = datetime.now(timezone.utc).isoformat()
        stats["elapsedSeconds"] = round(time.time() - start, 2)
        _write_stats(stats_file, stats)
        writer.manifest(stats)
        progress(True)

    return stats
