# PupWiki Geo Pipeline
PUPWIKI_DATA_ROOT=.
PUPWIKI_PLACES_VERSION=v1

# Full US OSM source on your Google Drive
PUPWIKI_OSM_GOOGLE_DRIVE_FILE_ID=1z3fynwYHrnx-9HzvsXrS1izorU8dD5AY
PUPWIKI_OSM_PBF=data-raw/osm/google-drive/us-latest.osm.pbf

# Optional Geofabrik fallback
PUPWIKI_OSM_GEOFABRIK_URL=https://download.geofabrik.de/north-america/us-latest.osm.pbf

# Optional Cloudflare R2 upload
R2_BUCKET=pupwiki-places
R2_PREFIX=places/v1
R2_CUSTOM_DOMAIN=https://static.pupwiki.com
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional MapTiler/Protomaps style for frontend MapLibre
PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
