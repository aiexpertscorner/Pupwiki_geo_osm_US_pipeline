  "seo": {
    "statePageMinPois": 1,
    "categoryPageMinPois": 1,
    "stateCategoryPageMinPois": 20,
    "cityPageMinPois": 10,
    "cityCategoryPageMinPois": 3,
    "cityCategoryMinAverageQuality": 40,
    "poiDetailPageMinQuality": 75
  },
  "cloudflare": {
    "mode": "hybrid",
    "r2Bucket": "pupwiki-places",
    "r2Prefix": "places/v1",
    "publicBaseUrl": "https://static.pupwiki.com/places/v1"
  }
